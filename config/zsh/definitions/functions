# Quick cd to project
cdproj() {
  cd $PROJECTS_ROOT_DIR/$1
}


stream() {
   $DOTFILES_PATH/config/hypr/scripts/stream "$@"
}

# yazi wrapper
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	command rm -f -- "$tmp"
}

