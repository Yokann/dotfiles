{
    "pulseaudio": {
        "tooltip": false,
        "scroll-step": 5,
        "format": "{icon}   {volume}%",
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "format-icons": {
            "headphone": "≤░ΜΜ",
            "headset": "≤░ΜΟ",
            "default": [
                "ΎΑο",
                "ΎΑπ",
                "ΎΑρ"
            ]
        },
        "format-muted": "ΎΑο {volume}%"
    },
    "network": {
        "format-wifi": "ΎΘτ  {essid}",
        "format-ethernet": "≤░σι  {ipaddr}/{cidr}",
        "format-disconnected": "≤░▓δ disconnected",
        "tooltip-format": "{ifname} via {gwaddr} ΎΔΒ",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
        "tooltip-format-ethernet": "{ifname} via {gwaddr} ΎΔΒ",
        "tooltip-format-disconnected": false
    },
    "backlight": {
        "tooltip": false,
        "format": "ΎΔτ {}%",
        "interval": 1,
        "on-scroll-up": "light -A 5",
        "on-scroll-down": "light -U 5"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "ΎΘο  {capacity}%",
        "format-plugged": "ΎΘο  {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "ΎΚΕ  ",
            "ΎΚΔ  ",
            "ΎΚΓ  ",
            "ΎΚΒ  ",
            "ΎΚΑ  "
        ]
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "clock": {
        "format": "ΎΑΩ  {:%H:%M  ΎΩ╡  %d/%m/%Y}",
        "on-click": "firefox -P Perso https://calendar.infomaniak.com/?view=week",
        // "tooltip": false
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 6,
            "weeks-pos": "left",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#f5bde6'><b>{}</b></span>",
                "days": "<span color='#f4dbd6'><b>{}</b></span>",
                "weeks": "<span color='#8aadf4'><b>W{}</b></span>",
                "weekdays": "<span color='#f5a97f'><b>{}</b></span>",
                "today": "<span color='#ed8796'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 200,
            "children-class": "child"
        },
        "modules": [
            "cpu",
            "memory",
            "disk",
            "network"
        ]
    },
    "cpu": {
        "interval": 5,
        "format": "≤░╗ι  {usage}%",
        "max-length": 10,
        "on-click": "$HYPR_CONFIG_PATH/scripts/foot_wrapper -e btop"
    },
    "memory": {
        "interval": 10,
        "format": "≤░Ξδ  {}%",
        "max-length": 10,
        "on-click": "$HYPR_CONFIG_PATH/scripts/foot_wrapper -e btop"
    },
    "disk": {
        "interval": 600,
        "format": "≤░ΜΛ  {percentage_free}%"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΔ┤",
            "deactivated": "≤░╖δ "
        }
    },
    "custom/playerctl": {
        "interval": 5,
        "tooltip": true,
        "return-type": "json",
        "format": "{icon}  {0}",
        "format-icons": {
            "Playing": "≤░Πο ",
            "Paused": "≤░ΡΞ "
        },
        "max-length": 50,
        "exec": "playerctl metadata --format '{\"alt\": \"{{status}}\", \"text\": \"<span>{{markup_escape(title)}} - {{markup_escape(artist)}}</span>\", \"tooltip\": \"{{playerName}} - {{markup_escape(title)}}\" }'",
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-scroll-up": "playerctl position 10+",
        "on-scroll-down": "playerctl position 10-"
    },
    "custom/launcher": {
        "format": "ΎΝΔ ",
        "on-click": "walker -m desktopapplications",
        "tooltip": false
    },
    "custom/updates": {
        "tooltip": true,
        "format": "{} ≤▒Ξ╖",
        "return-type": "json",
        "exec-if": "$HYPR_CONFIG_PATH/scripts/updatechecker check",
        "exec": "$HYPR_CONFIG_PATH/scripts/updatechecker status",
        "interval": 3600,
        "on-click": "$HYPR_CONFIG_PATH/scripts/foot_wrapper -e yay -Syu"
    },
    "hyprland/workspaces": {
        "format": "{icon}  {windows}",
        "window-rewrite-default": "≤▒Γυ",
        "window-rewrite": {
            "vivaldi": "ΎΤΙ",
            "class<firefox>": "ΎΚσ",
            "foot|class<kitty>": "ΌηΧ",
            "code|cursor": "≤░ρη",
            "discord": "≤░βψ",
            "slack": "ΎΗα",
            "pavucontrol": "≤░ΜΟ",
            "cider": "ΌεΣ",
            "1password": "≤░οζ",
            "mpv": "ΎΞχ",
            "pcmanfm|nemo": "ΎΒ╝",
            "signal": "≤░φ╣",
            "class<chrome-www.youtube.com__-Default>": "ΎΖς",
            "class<ticktick>": "Όφπ",
            "steam": "ΎΗ╢",
            "claude": "≤░ψ▓"
        }
    },
    "hyprland/window": {
        "format": "{title}",
        "icon": true,
        "separate-outputs": true,
        "rewrite": {
            "(.*) έΑΦ Mozilla Firefox": "$1",
            "(.*) - Youtube": "Youtube",
        },
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon} {0}",
        "format-icons": {
            "notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
            "none": "ΎΓλ ",
            "dnd-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
            "dnd-none": "ΎΘ╖ ",
            "inhibited-notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
            "inhibited-none": "ΎΓλ ",
            "dnd-inhibited-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
            "dnd-inhibited-none": "ΎΘ╖ "
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "custom/twitch": {
        "format": "ΎΘρ",
        "tooltip": false,
        "on-click": "walker -m menus:twitch",
        "on-click-middle": "livestream-ctl notif"
    },
    // Custom Pomodoro module install `cargo install pomodoro-cli`
    "custom/pomo": {
        "format": "ΌΑΒ {}",
        "exec": "pomodoro-cli status --format json",
        "return-type": "json",
        "on-click": "pomodoro-cli start --add 5m --notify",
        "on-click-middle": "pomodoro-cli pause",
        "on-click-right": "pomodoro-cli stop",
        "interval": 1
    }
}
