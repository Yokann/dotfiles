#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

header()  { echo -e "\n${BOLD}${CYAN}==> $*${RESET}"; }
success() { echo -e "${GREEN}  ✓ $*${RESET}"; }
skip()    { echo -e "${YELLOW}  - $*${RESET}"; }
info()    { echo -e "    $*"; }

disk_free() { df -h / | awk 'NR==2{print $4}'; }

confirm() {
  [[ "${AUTO:-}" == "1" ]] && return 0
  read -rp "  Run? [y/N] " ans
  [[ "${ans,,}" == "y" ]]
}

has() { command -v "$1" &>/dev/null; }

BEFORE=$(disk_free)
echo -e "${BOLD}Disk free before: ${BEFORE}${RESET}"

# ── yay / paccache ──────────────────────────────────────────────────────────
header "Package cache (yay)"
if has yay; then
  if has paccache; then
    info "paccache -rk2   (keep 2 latest versions of installed packages)"
    info "paccache -ruk0  (drop cached versions of uninstalled packages)"
    info "yay -Sc --aur   (clean AUR build dirs)"
    if confirm; then
      sudo paccache -rk2
      sudo paccache -ruk0
      yay -Sc --aur --noconfirm
      success "Package cache trimmed (2 versions kept)"
    fi
  else
    info "yay -Sc --noconfirm  (install pacman-contrib for 2-version keep)"
    if confirm; then
      yay -Sc --noconfirm
      success "yay cache cleaned"
    fi
  fi
else
  skip "yay not found"
fi

# ── systemd journal ─────────────────────────────────────────────────────────
header "systemd journal (keep last 7 days / 200 MB)"
info "journalctl --vacuum-time=7d --vacuum-size=200M"
if confirm; then
  sudo journalctl --vacuum-time=7d --vacuum-size=200M
  success "Journal vacuumed"
fi

# ── Docker ──────────────────────────────────────────────────────────────────
header "Docker system prune"
if has docker && docker info &>/dev/null 2>&1; then
  info "docker system prune --all"
  if confirm; then
    docker system prune --all --force
    success "Docker pruned"
  fi
else
  skip "Docker not running or not installed"
fi

# ── npm cache ───────────────────────────────────────────────────────────────
header "npm cache"
if has npm; then
  info "npm cache clean --force"
  if confirm; then
    npm cache clean --force
    success "npm cache cleaned"
  fi
else
  skip "npm not found"
fi

# ── pip cache ───────────────────────────────────────────────────────────────
header "pip cache"
if has pip; then
  info "pip cache purge"
  if confirm; then
    pip cache purge
    success "pip cache cleaned"
  fi
else
  skip "pip not found"
fi

# ── cargo registry / build cache ────────────────────────────────────────────
header "Cargo cache (~/.cargo/registry + target leftovers)"
if has cargo; then
  if has cargo-cache; then
    info "cargo cache --autoclean"
    if confirm; then
      cargo cache --autoclean
      success "cargo cache cleaned"
    fi
  else
    CARGO_REG="${CARGO_HOME:-$HOME/.cargo}/registry/cache"
    if [[ -d "$CARGO_REG" ]]; then
      SIZE=$(du -sh "$CARGO_REG" 2>/dev/null | cut -f1)
      info "Remove $CARGO_REG  (${SIZE})"
      if confirm; then
        rm -rf "$CARGO_REG"
        success "Cargo registry cache removed"
      fi
    else
      skip "No cargo registry cache found"
    fi
  fi
else
  skip "cargo not found"
fi


# ── Terraform ───────────────────────────────────────────────────────────────
header "Terraform cache"
if has terraform; then
  # Global plugin cache (respects TF_PLUGIN_CACHE_DIR or the default path)
  TF_PLUGIN_DIR="${TF_PLUGIN_CACHE_DIR:-$HOME/.terraform.d/plugin-cache}"
  if [[ -d "$TF_PLUGIN_DIR" ]]; then
    SIZE=$(du -sh "$TF_PLUGIN_DIR" 2>/dev/null | cut -f1)
    info "Remove global plugin cache $TF_PLUGIN_DIR  (${SIZE})"
    if confirm; then
      rm -rf "$TF_PLUGIN_DIR"
      success "Terraform plugin cache removed"
    fi
  else
    skip "No global plugin cache found"
  fi

  # Local .terraform/ dirs — need terraform init to restore
  mapfile -t TF_DIRS < <(find "$HOME" \
    \( -path "$HOME/.terraform.d" -o -path "*/node_modules" -o -path "*/.git" \) -prune \
    -o -name ".terraform" -type d -print 2>/dev/null)
  if [[ ${#TF_DIRS[@]} -gt 0 ]]; then
    TOTAL=$(du -sh "${TF_DIRS[@]}" 2>/dev/null | tail -1 | cut -f1)
    info "Found ${#TF_DIRS[@]} local .terraform/ dir(s)  (~${TOTAL} total)"
    info "  (each requires 'terraform init' to restore)"
    if confirm; then
      for d in "${TF_DIRS[@]}"; do rm -rf "$d"; done
      success "Local .terraform/ dirs removed"
    fi
  else
    skip "No local .terraform/ dirs found"
  fi
else
  skip "terraform not found"
fi

# ── Thumbnail cache ─────────────────────────────────────────────────────────
header "Thumbnail cache (~/.cache/thumbnails)"
THUMB="$HOME/.cache/thumbnails"
if [[ -d "$THUMB" ]]; then
  SIZE=$(du -sh "$THUMB" 2>/dev/null | cut -f1)
  info "Remove $THUMB  (${SIZE})"
  if confirm; then
    rm -rf "$THUMB"
    success "Thumbnails removed"
  fi
else
  skip "No thumbnail cache found"
fi

# ── Flatpak unused runtimes ─────────────────────────────────────────────────
header "Flatpak unused runtimes"
if has flatpak; then
  info "flatpak uninstall --unused"
  if confirm; then
    flatpak uninstall --unused --noninteractive
    success "Unused Flatpak runtimes removed"
  fi
else
  skip "flatpak not found"
fi

# ── Summary ─────────────────────────────────────────────────────────────────
AFTER=$(disk_free)
echo -e "\n${BOLD}Disk free before: ${BEFORE}${RESET}"
echo -e "${BOLD}Disk free after:  ${AFTER}${RESET}"
echo -e "${GREEN}Done.${RESET}"
